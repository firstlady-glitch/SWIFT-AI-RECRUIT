NEXT_PUBLIC_SUPABASE_URL=supabase_url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=supabase_publishable_default_key
NEXT_PUBLIC_SUPABASE_ANON_KEY=supabase_anon_key
NEXT_PUBLIC_SUPABASE_ROLE_KEY=supabase_service_role_key
# Recommended for Paystack webhook + server fulfillment (bypass RLS)
# SUPABASE_SERVICE_ROLE_KEY=supabase_service_role_key

# Groq Chat Completions (see plan/groq). Used by server API routes via process.env.
NEXT_PUBLIC_GROQ_API_KEY=groq_api_key
# GROQ_MODEL=llama-3.3-70b-versatile

CLOUDINARY_URL=cloudinary_url

# Paystack (NGN). Set both for /api/config acceptPayments.
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxxx
PAYSTACK_SECRET_KEY=sk_test_xxxx
# Optional; defaults to NGN
# PAYSTACK_CURRENCY=NGN
# Override plan amounts (kobo): PAYSTACK_KOBO_CAREER_PLUS_MONTHLY=2500000

# Contact form → Nodemailer
# GMAIL_USER=you@gmail.com
# GMAIL_APP_PASSWORD=app_password_16_chars
# CONTACT_INBOX_EMAIL=support@swiftairecruit.com

# App URL for Paystack callback + emails
# NEXT_PUBLIC_APP_URL=https://your-domain.com

# Paystack dashboard: set webhook URL to https://your-domain.com/api/paystack/webhook
